# ═══════════════════════════════════════════════
# POLYMARKET QUANT BOT — ENVIRONMENT CONFIG
# ═══════════════════════════════════════════════
# Copy to .env and fill in values.
# NEVER commit .env to git.

# ── Safety ──────────────────────────────────────
# Paper trading is the only mode until this is true
ENABLE_REAL_TRADING=false
DRY_RUN=true

# ── Scanner ─────────────────────────────────────
SCAN_INTERVAL_SECONDS=30
MARKET_LIMIT=500
MIN_LIQUIDITY=500
CLOB_CONCURRENCY=15          # Max concurrent CLOB requests

# ── Thresholds ───────────────────────────────────
MIN_EDGE_PCT=0.5             # Minimum edge % to flag an opportunity
MIN_VIG_PCT=2.0              # Flag tournament groups above this vig
MIN_CONFIDENCE=0.4           # Signal confidence threshold (0-1)

# ── Paper Trading ────────────────────────────────
PAPER_STARTING_BALANCE=10000
PAPER_MAX_POSITION_SIZE=500  # Max USD per trade
PAPER_MAX_DAILY_LOSS=1000    # Kill switch: stop if daily loss exceeds this
PAPER_MAX_OPEN_POSITIONS=10  # Max simultaneous open positions
PAPER_MAX_EXPOSURE_PCT=0.40  # Max % of starting balance deployed at once

# ── Polymarket credentials (for real trading only) ──
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
WALLET_ADDRESS=

# ── Alerts ───────────────────────────────────────
DISCORD_WEBHOOK_URL=          # https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=            # https://hooks.slack.com/services/...
ALERT_MIN_EDGE_PCT=3.0        # Min edge % to trigger opportunity alert
ALERT_COOLDOWN_MINUTES=60     # Re-alert same market after this many minutes
ALERT_DIGEST_HOUR=8           # UTC hour for daily digest (0-23)
ALERT_ON_OPPORTUNITY=true     # Alert on VALUE/ARB signals
ALERT_ON_CLOSE=true           # Alert on position close
ALERT_ON_DIGEST=true          # Send daily digest

# ── Strategy Engine ──────────────────────────────
DISABLE_STRATEGIES=           # Comma-separated: momentum,spread_maker,cross_platform_value
MOMENTUM_MIN_POINTS=4         # Min historical snapshots to compute momentum
MOMENTUM_LOOKBACK_MINUTES=120 # History window for momentum calc
MOMENTUM_MIN_VELOCITY=0.04    # Min price change per hour to flag
MOMENTUM_MIN_R2=0.70          # Min R² of trend fit (0-1)
SPREAD_TOP_N=10               # Max spread-maker signals per scan

# ── External Odds APIs ───────────────────────────
ENABLE_EXTERNAL_ODDS=true    # Fetch Kalshi + PredictIt for cross-platform value
EXTERNAL_ODDS_EVERY_N=3      # Refresh external odds every N scan cycles
THE_ODDS_API_KEY=            # https://the-odds-api.com/ (optional, Pinnacle odds)
KALSHI_API_KEY=              # https://kalshi.com/ (not required for public data)

# ── API Endpoints (defaults fine) ────────────────
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── Database ─────────────────────────────────────
# SQLite (dev):
DATABASE_URL=sqlite:///./data/polymarket.db
# PostgreSQL (prod):
# DATABASE_URL=postgresql://user:password@host:5432/polymarket

# ── Auth (SaaS) ──────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Stripe ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ── App / Environment ────────────────────────────
ENV=development              # development | production | test
DEBUG=false
APP_VERSION=0.1.0
FRONTEND_URL=http://localhost:3000   # Used in password reset emails

# ── Email (SMTP) ─────────────────────────────────
# Leave blank in dev — emails are printed to console instead
SMTP_HOST=                   # e.g. smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=                   # SMTP username / API key
SMTP_PASSWORD=               # SMTP password
EMAIL_FROM=noreply@yourdomain.com

# ── Waitlist / Contact ────────────────────────────
WAITLIST_NOTIFY_EMAIL=       # Your email — get notified on new signups/contact forms

# ── Frontend ─────────────────────────────────────
# Set this in frontend/.env.local (not here)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/scanner.log

# ── CORS ─────────────────────────────────────────
# Comma-separated allowed origins for production
# ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
